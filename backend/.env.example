# Copy to backend/.env and fill in. All vars are optional for generic IMAP accounts.

# Dev mode: disable the localhost shared-secret token so the Vite dev server can connect.
RAPLMAIL_DEV=1

# Microsoft 365 (Azure app registration - see README "OAuth setup")
RAPLMAIL_MS_CLIENT_ID=
# Use a tenant-specific authority instead of /common if you want to lock to one org:
# RAPLMAIL_MS_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# Gmail / Google Workspace (Google Cloud "Desktop app" OAuth client)
RAPLMAIL_GOOGLE_CLIENT_ID=
RAPLMAIL_GOOGLE_CLIENT_SECRET=
