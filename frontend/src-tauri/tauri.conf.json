{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RaplMail",
  "version": "0.9.1",
  "identifier": "eu.a123systems.raplmail",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RaplMail",
        "label": "main",
        "width": 1280,
        "height": 840,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/raplmail-backend"],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/a123systems/raplmail/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2MkQ1NTdBMjNFRTExQTUKUldTbEVlNGplbFV0WmlZVE1ieWVuQVFXbERrMWlWL01LOG9CZlc4SHhFSTFZVVR6LzU0V1U1OWkK",
      "windows": { "installMode": "passive" }
    }
  }
}
